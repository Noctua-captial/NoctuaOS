# Noctua OS — provider keys (copy to .env.local; restart the dev server after edits)
# All keys are optional. The model router (lib/models.ts) falls back to any
# configured provider; with no keys, the agent bench stays dormant and the
# rest of the terminal keeps working.

# xAI — Strix / adversarial (grok-4.3)
XAI_API_KEY=

# Anthropic — Dossier, Thesis, Industry, Catalyst (claude-fable-5);
# IC Synthesis (claude-opus-4-8); Night Vision, Chat (claude-sonnet-4-6)
ANTHROPIC_API_KEY=

# OpenAI — Accounting, Evidence Auditor (gpt-5.5); Valuation (gpt-5.5-pro);
# Vault embeddings (text-embedding-3-small)
OPENAI_API_KEY=

# --- Augury (trader-intelligence module) ---------------------------------
# Both optional. Without them Augury still works: ingestion no-ops without the
# scraper token, and market history falls back to the keyless ~2y source.

# Apify — Tweet Scraper actor token, for backfilling/polling tracked traders'
# post history. Set the handles to track in lib/augury/authors.config.ts.
APIFY_TOKEN=

# Polygon.io — adjusted deep daily + 5-minute history for point-in-time
# backtests. Absent → keyless fallback (≈2y daily closes, no intraday).
POLYGON_API_KEY=

# Per-agent model overrides — replace the model ID on the agent's preferred
# provider. See the routing table at /lab. Examples:
# NOCTUA_MODEL_DOSSIER=
# NOCTUA_MODEL_THESIS=
# NOCTUA_MODEL_ACCOUNTING=
# NOCTUA_MODEL_INDUSTRY=
# NOCTUA_MODEL_CATALYST=
# NOCTUA_MODEL_VALUATION=
# NOCTUA_MODEL_STRIX=
# NOCTUA_MODEL_EVIDENCE_AUDITOR=
# NOCTUA_MODEL_SYNTHESIS=
# NOCTUA_MODEL_NIGHTVISION=
# NOCTUA_MODEL_CHAT=
# NOCTUA_MODEL_EMBEDDINGS=

# --- Supabase / Vercel (database + deployment) ---------------------------
# Required in production (unlike the provider keys above). The connection
# strings come from the Supabase dashboard: Project Settings -> Database.

# Pooled connection (Supavisor, transaction mode) used by the app at runtime
# on Vercel serverless. Port 6543. Keep pgbouncer=true and connection_limit=1
# so each serverless invocation holds a single pooled connection.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct connection (no pooler). Port 5432. Used for drizzle-kit migrations,
# the seed script, and the local Augury backfill — operations the transaction
# pooler can't serve (DDL / prepared statements).
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Shared secret guarding the Vercel Cron routes (/api/augury/poll & /process).
# Vercel sends it as `Authorization: Bearer ${CRON_SECRET}` on scheduled GETs.
# Generate a long random value, e.g. `openssl rand -hex 32`.
CRON_SECRET=

# Optional access gate for the deployed app (see proxy.ts). When set, the whole
# site requires this password via HTTP Basic auth or a matching cookie; Vercel
# cron requests bypass it. Leave blank to disable the gate (e.g. local dev).
AUGURY_ACCESS_PASSWORD=
