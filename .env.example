# Noctua OS — provider keys (copy to .env.local; restart the dev server after edits)
# All keys are optional. The model router (lib/models.ts) falls back to any
# configured provider; with no keys, the agent bench stays dormant and the
# rest of the terminal keeps working.

# xAI — Strix / adversarial (grok-4.3)
XAI_API_KEY=

# Anthropic — Dossier, Thesis, Industry, Catalyst (claude-fable-5);
# IC Synthesis (claude-opus-4-8); Night Vision, Chat (claude-sonnet-4-6)
ANTHROPIC_API_KEY=

# OpenAI — Accounting, Evidence Auditor (gpt-5.5); Valuation (gpt-5.5-pro);
# Vault embeddings (text-embedding-3-small)
OPENAI_API_KEY=

# Per-agent model overrides — replace the model ID on the agent's preferred
# provider. See the routing table at /lab. Examples:
# NOCTUA_MODEL_DOSSIER=
# NOCTUA_MODEL_THESIS=
# NOCTUA_MODEL_ACCOUNTING=
# NOCTUA_MODEL_INDUSTRY=
# NOCTUA_MODEL_CATALYST=
# NOCTUA_MODEL_VALUATION=
# NOCTUA_MODEL_STRIX=
# NOCTUA_MODEL_EVIDENCE_AUDITOR=
# NOCTUA_MODEL_SYNTHESIS=
# NOCTUA_MODEL_NIGHTVISION=
# NOCTUA_MODEL_CHAT=
# NOCTUA_MODEL_EMBEDDINGS=
