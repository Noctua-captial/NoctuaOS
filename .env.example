# Noctua OS — environment (copy to .env.local; restart the dev server after edits)

# --- Database (REQUIRED) — Supabase Postgres ---
# The app connects with postgres-js over a Supabase Supavisor pooler. On Vercel,
# set this in Project Settings → Environment Variables for ALL environments
# (Production, Preview, Development).
#
# RECOMMENDED — SESSION pooler (port 5432):
#   postgres://<role>.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
# Why session (5432), not transaction (6543): the app issues several queries per
# request via Promise.all. If concurrent queries exceed the postgres-js pool
# size, the transaction pooler poisons the pool (queries hang); the session
# pooler queues the overflow cleanly. (The transaction pooler also works if you
# keep NOCTUA_PG_MAX safely above the per-request fan-out — but session is
# safer for this workload.)
# Notes:
#   - Use the POOLER host (…pooler.supabase.com), NOT db.<ref>.supabase.co — the
#     direct host is IPv6-only and unreachable from Vercel's serverless runtime.
#   - TLS is auto-enabled for *.supabase.co/com hosts; ?sslmode=require optional.
#   - Find the exact string in Supabase → Project Settings → Database →
#     Connection string → "Session pooler".
DATABASE_URL=

# Postgres connection-pool size per serverless instance (postgres-js `max`).
# Must stay above the largest per-request query fan-out (default 10).
# NOCTUA_PG_MAX=10

# All provider keys below are optional. The model router (lib/models.ts) falls
# back to any configured provider; with no keys, the agent bench stays dormant
# and the rest of the terminal keeps working.

# xAI — Strix / adversarial (grok-4.3)
XAI_API_KEY=

# Anthropic — Dossier, Thesis, Industry, Catalyst (claude-fable-5);
# IC Synthesis (claude-opus-4-8); Night Vision, Chat (claude-sonnet-4-6)
ANTHROPIC_API_KEY=

# OpenAI — Accounting, Evidence Auditor (gpt-5.5); Valuation (gpt-5.5-pro);
# Vault embeddings (text-embedding-3-small)
OPENAI_API_KEY=

# --- Reliability / cost knobs (optional) ---
# Cap on generated tokens per agent call (bounds cost + latency).
# NOCTUA_MAX_OUTPUT_TOKENS=8000
# Extra attempts when a model returns JSON that fails schema validation.
# NOCTUA_OBJECT_RETRIES=2
# SDK-level retries for transient provider/API errors (rate limits, 5xx).
# NOCTUA_API_RETRIES=2
# Per-model health-probe timeout and result cache (used by /api/health/models and /lab).
# NOCTUA_HEALTH_TIMEOUT_MS=12000
# NOCTUA_HEALTH_CACHE_MS=60000

# --- Access control & rate limiting ---
# Set a shared access token to lock the terminal: every page and API route then
# requires it (sign in at /login, which sets an httpOnly cookie). REQUIRED before
# exposing the app publicly — it is what protects the server-rendered research
# and the /api/export/traces training-data export. Leave unset for open local dev.
# NOCTUA_ACCESS_TOKEN=change-me-to-a-long-random-string
# Per-IP rate limits (always on, even without a token). Window + caps:
# NOCTUA_RATELIMIT_WINDOW_MS=60000
# NOCTUA_RATELIMIT_GENERAL=120
# NOCTUA_RATELIMIT_EXPENSIVE=20

# --- SEC EDGAR (keyless, but a descriptive User-Agent is REQUIRED) ---
# SEC's fair-access policy requires a User-Agent identifying your app + a contact
# email, and ≤10 requests/sec. Without it, SEC may throttle or block ingestion,
# fundamentals, and insider (Form 4) fetches. Set this before running Night
# Vision or pulling filings into the Vault.
# EDGAR_USER_AGENT="Noctua OS (you@example.com)"
# Minimum spacing between SEC requests across the app, in ms (default 150 ≈ 6.7/s).
# NOCTUA_SEC_MIN_INTERVAL_MS=150

# Per-agent model overrides — replace the model ID on whichever provider is
# selected (first in the chain with a key). See the routing table at /lab. Examples:
# NOCTUA_MODEL_DOSSIER=
# NOCTUA_MODEL_THESIS=
# NOCTUA_MODEL_ACCOUNTING=
# NOCTUA_MODEL_INDUSTRY=
# NOCTUA_MODEL_CATALYST=
# NOCTUA_MODEL_VALUATION=
# NOCTUA_MODEL_STRIX=
# NOCTUA_MODEL_EVIDENCE_AUDITOR=
# NOCTUA_MODEL_SYNTHESIS=
# NOCTUA_MODEL_NIGHTVISION=
# NOCTUA_MODEL_CHAT=
# NOCTUA_MODEL_EMBEDDINGS=
